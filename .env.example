# Copy to .env and fill in your values

DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Optional: server ID so slash commands appear immediately (right‑click server → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# Optional: Conduit indexer (for indexer_verifications.py / future use)
INDEXER_API_KEY=your_indexer_api_key_here

# Heartbeat check: run every N seconds (default 300 = 5 min)
HEARTBEAT_CHECK_INTERVAL_SECONDS=300
# Send DM if last heartbeat is older than N seconds (default 1800 = 30 min)
HEARTBEAT_STALE_THRESHOLD_SECONDS=1800
